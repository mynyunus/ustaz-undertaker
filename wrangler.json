{
  "name": "ustaz-undertaker",
  "main": "worker.js",
  "compatibility_date": "2026-04-26",
  "workers_dev": false,
  "routes": [
    {
      "pattern": "ustazundertaker.com",
      "custom_domain": true
    },
    {
      "pattern": "www.ustazundertaker.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "vars": {
    "GOOGLE_DOC_ID": "1gK5AdhT7wEc_M8dYzRBTcjbNtA0FrYCDvjqCdn_bGgM"
  },
  "build": {
    "command": "rm -rf public && mkdir -p public && cp index.html styles.css script.js robots.txt sitemap.xml public/ && mkdir -p public/assets && cp -R assets/. public/assets/"
  }
}
